# --- Provider selection (per-service local<->cloud switch; defaults are cloud) ---
# STT_BACKEND:   groq (cloud) | local (Speaches server)
# IMAGE_BACKEND: hf   (cloud) | comfyui (local ComfyUI server)
STT_BACKEND=groq
IMAGE_BACKEND=hf

# Local providers (used when the backends above are local/comfyui). Point at the
# machine running Speaches + ComfyUI (NOT localhost if it's a different PC).
SPEACHES_BASE_URL=http://192.168.0.186:8001
SPEACHES_MODEL=Systran/faster-whisper-large-v3
COMFYUI_BASE_URL=http://192.168.0.186:8188

# Groq Whisper (speech-to-text)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=whisper-large-v3
# Fast Groq LLM for AI Imagine child-safety moderation (app/moderation.py).
# If GROQ_API_KEY is unset, moderation is skipped (keyword filter still applies).
GROQ_LLM_MODEL=llama-3.1-8b-instant

# HuggingFace FLUX (image generation)
HF_API_TOKEN=your-huggingface-token

# Save each incoming device utterance as a WAV under debug_audio/ (1 to enable)
SAVE_DEVICE_AUDIO=0

# --- Multi-provider STT (ADR-0002) ---
# Manager-api supplies the ACTIVE provider; leave base URL empty to use last-resort only.
MANAGER_API_BASE_URL=http://localhost:3000
SERVICE_SECRET_KEY=your-service-secret-key
STT_PROVIDER_TTL_S=300
# Fixed fallback used on hard failure / manager-api down / unknown provider.
STT_LAST_RESORT_PROVIDER=groq
# Language pinned on every STT request (ISO-639-1). Without this Whisper auto-detects
# per utterance and mis-reads short English clips as Hindi, returning Devanagari.
# Set to empty for auto-detect (multi-language deployments).
STT_LANGUAGE=en
# Keys used only when that provider is the last-resort (primary keys come from manager-api).
DEEPGRAM_API_KEY=
SARVAM_API_KEY=
# saarika:v1/v2/flash are retired by Sarvam — do not use them. v2.5 is the current
# transcribe model. Sarvam takes BCP-47 codes, so STT_LANGUAGE=en is sent as en-IN.
SARVAM_MODEL=saarika:v2.5
