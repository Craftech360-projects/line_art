# Groq Whisper (speech-to-text)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=whisper-large-v3
# Fast Groq LLM for AI Imagine child-safety moderation (app/moderation.py).
# If GROQ_API_KEY is unset, moderation is skipped (keyword filter still applies).
GROQ_LLM_MODEL=llama-3.1-8b-instant

# HuggingFace FLUX (image generation)
HF_API_TOKEN=your-huggingface-token

# Save each incoming device utterance as a WAV under debug_audio/ (1 to enable)
SAVE_DEVICE_AUDIO=0
