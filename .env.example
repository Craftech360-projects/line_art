# --- Provider selection (per-service local<->cloud switch; defaults are cloud) ---
# STT_BACKEND:   groq (cloud) | local (Speaches server)
# IMAGE_BACKEND: hf   (cloud) | comfyui (local ComfyUI server)
STT_BACKEND=groq
IMAGE_BACKEND=hf

# Local providers (used when the backends above are local/comfyui). Point at the
# machine running Speaches + ComfyUI (NOT localhost if it's a different PC).
SPEACHES_BASE_URL=http://192.168.0.186:8001
SPEACHES_MODEL=Systran/faster-whisper-large-v3
COMFYUI_BASE_URL=http://192.168.0.186:8188

# Groq Whisper (speech-to-text)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=whisper-large-v3
# Fast Groq LLM for AI Imagine child-safety moderation (app/moderation.py).
# If GROQ_API_KEY is unset, moderation is skipped (keyword filter still applies).
GROQ_LLM_MODEL=llama-3.1-8b-instant

# HuggingFace FLUX (image generation)
HF_API_TOKEN=your-huggingface-token

# Save each incoming device utterance as a WAV under debug_audio/ (1 to enable)
SAVE_DEVICE_AUDIO=0
